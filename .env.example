# Copie este arquivo para .env e preencha (nunca commite o .env).
#   copy .env.example .env
#
# --- Pesquisa web no dashboard (um dos dois conjuntos) ---
#
# Opção A — Brave Search API (recomendado: uma chave só)
# Crie em: https://api.search.brave.com/
BRAVE_API_KEY=

# Opção B — Google Programmable Search (Custom Search JSON)
# 1) Google Cloud Console: ative "Custom Search API" e crie uma API key REST
# 2) https://programmablesearchengine.google.com/ — crie um mecanismo e copie o "Search engine ID" (cx)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Texto extra na query quando marcar "Ampliar termo" no painel (opcional)
# ARBILOCAL_BUSCA_FORNECEDOR_SUFFIX=fornecedor atacado distribuidor compra B2B Brasil

# Limite de buscas por IP por hora (opcional, padrão 40)
# ARBILOCAL_RATE_LIMIT_BUSCA=40

# --- Outros (opcional) ---
# ML_ACCESS_TOKEN=
# ARBILOCAL_API_KEY=
