# Copie este arquivo para .env e preencha (nunca commite o .env).
#   copy .env.example .env
#
# --- Pesquisa web no dashboard (uma fonte basta) ---
#
# Opção 0 — SearXNG (sua instância no GitHub / self-hosted)
# URL base SEM /search no final. Ex.: https://pesquisa.seudominio.com ou http://127.0.0.1:8080
# No servidor SearXNG, em settings.yml, em search.formats inclua "json" (senão a API devolve 403).
# Docs: https://docs.searxng.org/dev/search_api.html
# SEARXNG_URL=
# SEARXNG_API_KEY=          # opcional — Authorization: Bearer (padrão)
# SEARXNG_API_KEY_HEADER=X-API-Key   # opcional — se a tua API usa outro header (valor = SEARXNG_API_KEY)
# SEARXNG_USERNAME=         # opcional — Basic auth
# SEARXNG_PASSWORD=
# SEARXNG_SSL_VERIFY=1      # 0 só se certificado inválido (não recomendado em produção)
# SEARXNG_CATEGORIES=general  # opcional
#
# Opção A — Brave Search API
# https://api.search.brave.com/
BRAVE_API_KEY=

# Opção B — Serper (Google via serper.dev — NÃO é a API CSE oficial)
# POST https://google.serper.dev/search  header X-API-KEY
# https://serper.dev/
SERPER_API_KEY=
# Ou: use a chave Serper no GOOGLE_API_KEY e deixe GOOGLE_CSE_ID vazio:
# SERPER_USE_GOOGLE_KEY=1
# GOOGLE_API_KEY=sua_chave_serper

# Opção C — Google Programmable Search (API oficial Custom Search JSON — precisa cx)
# Cloud Console + https://programmablesearchengine.google.com/
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Texto extra na query quando marcar "Ampliar termo" no painel (opcional)
# ARBILOCAL_BUSCA_FORNECEDOR_SUFFIX=fornecedor atacado distribuidor compra B2B Brasil

# Limite de buscas por IP por hora (opcional, padrão 40)
# ARBILOCAL_RATE_LIMIT_BUSCA=40

# --- Outros (opcional) ---
# ML_ACCESS_TOKEN=
# ARBILOCAL_API_KEY=
